    <meta content="Martin Alvarez-Espinar" name="author">
    
    
    <script src="http://api.simile-widgets.org/exhibit/3.0.0rc1/exhibit-api.js" type="text/javascript"></script>
    <link href="data.json" type="application/json" rel="exhibit-data" />

  </head>
  <body>

    
    <div id="main-content">
        <div id="title-panel">
          <h1>Parques para adultos en Gijón</h1>
        </div>
    
        <div id="top-panels">
            <table width="100%"><tr>
             <td>Facets for sorting and browsing go here</td>
            </tr></table>
        </div>
        
        <div ex:role="viewPanel" style="padding: 1em 0.5in;">
        
            <div ex:role="view"
                ex:label="Details"
                ex:viewClass="Tile"
                ex:showAll="true">
            </div>
        </div>
  
  
  </body>
